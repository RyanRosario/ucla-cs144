# --------------------------------------------------------------------------
# Eastern Sierra Snow Dashboard — Environment Variables
# --------------------------------------------------------------------------
# Copy this file to .env and fill in the values:
#
#   cp .env.template .env
#
# .env is git-ignored and should NEVER be committed.
# --------------------------------------------------------------------------

# --- Server ---------------------------------------------------------------

PORT=3000

# --- Weather Underground (Crowley Lake weather station) -------------------
# The app falls back to Open-Meteo automatically if these are missing or
# invalid, so they are optional for a basic demo.
#
# How to get a Weather Underground API key:
#   1. Go to https://www.wunderground.com/member/api-keys
#   2. Sign in or create a free account.
#   3. Click "Purchase Key" and select the free Anvil Plan
#      (up to 1,500 calls/day at no cost).
#   4. Copy the 32-character hex key and paste it below.
#
# The station ID below is the Crowley Lake Fishcamp PWS. Change it if you
# want data from a different station.

WU_API_KEY=
WU_STATION_ID=KCAMAMMO76

# --- Bearer Token demo (/api/secret-report) -------------------------------
# Any string you choose. The frontend must send it in the Authorization
# header as:  Authorization: Bearer <token>
#
# For the in-class demo the README uses:  cs144-secret-token-2026

BEARER_TOKEN=cs144-secret-token-2026

# --- API Key demo (/api/snow-quality) -------------------------------------
# Any string you choose. The frontend sends it as a query parameter:
#   /api/snow-quality?apiKey=<key>
#
# For the in-class demo the README uses:  mammoth-powder-key-2026

API_KEY=mammoth-powder-key-2026
