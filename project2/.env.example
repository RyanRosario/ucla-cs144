# Copy this file to .env and adjust values as needed.
# .env is gitignored; .env.example is checked in.

# ---------------------------------------------------------------------------
# USE_DB — whether to read from MongoDB or local fixture files.
#
#   false  Reads from fixtures/*.json. No database required.
#          Use this until we cover MongoDB in lecture.
#
#   true   Reads from MongoDB. Requires the database to be running and
#          the Mongoose queries in utils/mongodb.js to be implemented.
#
# Working against fixtures first, then switching to a real database, is
# standard professional practice — not a workaround. It lets you verify
# your routing, caching, and webpage logic without depending on a network
# or a database that you have to set up and seed.
# ---------------------------------------------------------------------------
USE_DB=false

# ---------------------------------------------------------------------------
# DEBUG — only relevant when USE_DB=true.
#
#   true   Connect to localhost:27017. Load sample/mammoth.bson into your
#          local MongoDB with mongorestore (see sample/README.md).
#
#   false  Connect to cs144.org:27017 (the class production server).
#          Requires MONGO_USER and MONGO_PASS to be set.
#          Use this only after you've validated your code locally.
#
# Recommended progression as you build the project:
#   1. USE_DB=false                     (no database needed)
#   2. USE_DB=true, DEBUG=true          (local Mongo, sample BSON loaded)
#   3. USE_DB=true, DEBUG=false         (production Mongo on cs144.org)
# ---------------------------------------------------------------------------
DEBUG=true

# ---------------------------------------------------------------------------
# MONGO_USER / MONGO_PASS — credentials for the production MongoDB.
#
# Only required when USE_DB=true and DEBUG=false. Get these from the project
# spec or your instructor. Not needed for local development.
# ---------------------------------------------------------------------------
# MONGO_USER=student
# MONGO_PASS=

# ---------------------------------------------------------------------------
# TOKEN_TTL_SECONDS — bearer token lifetime, in seconds.
#
# Used by Task 6A (POST /api/auth/token). Each issued token is stored in
# Redis with this TTL; after it expires, the client must re-issue.
#
# 3600 (1 hour) is a reasonable default for a short-lived guest token.
# Lower values make expiration easier to observe while testing; higher
# values are friendlier during long debugging sessions.
# ---------------------------------------------------------------------------
TOKEN_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Rate limits — Task 6B. Both expressed in requests per minute.
#
# Defaults are what we test against. You may RAISE these locally for your
# own testing, but please don't lower them and please commit the defaults.
# ---------------------------------------------------------------------------

# POST /api/auth/token, keyed by client IP.
TOKEN_RATE_LIMIT_PER_MINUTE=10

# /api/lifts and /api/trails, keyed by bearer token.
# Note: the webpage auto-refreshes every 15 seconds (4 req/min), staying
# under this limit during normal browsing. The limit is exercised when the
# user actively interacts (form submissions, manual refreshes). Your page
# must handle the 429 response gracefully and show the user when they can
# retry — see the rate-limit handler TODO in auth/limits.js for the
# response shape.
API_RATE_LIMIT_PER_MINUTE=5
